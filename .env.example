# Copy this file to backend/.env (do NOT commit real secrets). Use environment variables or a secrets store in production.

# MongoDB
MONGO_URL="mongodb+srv://<user>:<password>@cluster.example.mongodb.net"
DB_NAME="cadence"

# JWT
JWT_SECRET="<strong-jwt-secret>"

# Emergent LLM key (Claude streaming)
EMERGENT_LLM_KEY="<emergent-llm-key>"

# Resend for emails
RESEND_API_KEY="<resend-api-key>"
SENDER_EMAIL="onboarding@resend.dev"

# Optional Sanity fallback token
DEFAULT_SANITY_TOKEN="<sanity-fallback-token>"

# CORS (frontend origin for local dev)
CORS_ORIGINS="http://localhost:3000"
